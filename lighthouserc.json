{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm --filter @control-plane/web start",
      "startServerReadyPattern": "started server on|Local:\\s*http|Ready in",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://127.0.0.1:3000/",
        "http://127.0.0.1:3000/agents",
        "http://127.0.0.1:3000/sessions",
        "http://127.0.0.1:3000/sessions/overview",
        "http://127.0.0.1:3000/sessions/costs",
        "http://127.0.0.1:3000/sessions/activity",
        "http://127.0.0.1:3000/sessions/tools",
        "http://127.0.0.1:3000/sessions/projects",
        "http://127.0.0.1:3000/kanban",
        "http://127.0.0.1:3000/mcps",
        "http://127.0.0.1:3000/channels",
        "http://127.0.0.1:3000/replay",
        "http://127.0.0.1:3000/webhooks",
        "http://127.0.0.1:3000/skills"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2"],
        "chromeFlags": "--no-sandbox --headless",
        "maxWaitForFcp": 45000,
        "maxWaitForLoad": 60000
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "interaction-to-next-paint": "off",
        "total-blocking-time": ["error", { "maxNumericValue": 200 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1800 }],
        "speed-index": ["warn", { "maxNumericValue": 3400 }],
        "uses-http2": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
