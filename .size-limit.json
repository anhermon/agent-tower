[
  {
    "name": "web-client-total",
    "path": "apps/web/.next/static/**/*.js",
    "limit": "500 KB",
    "gzip": true,
    "brotli": false
  },
  {
    "name": "web-framework",
    "path": "apps/web/.next/static/chunks/framework-*.js",
    "limit": "60 KB",
    "gzip": true,
    "brotli": false
  },
  {
    "name": "web-main",
    "path": "apps/web/.next/static/chunks/main-*.js",
    "limit": "40 KB",
    "gzip": true,
    "brotli": false
  },
  {
    "name": "web-css",
    "path": "apps/web/.next/static/css/*.css",
    "limit": "80 KB",
    "gzip": true,
    "brotli": false
  }
]
