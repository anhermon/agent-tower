{
  "$schema": "https://modelcontextprotocol.io/schema/mcp.json",
  "mcpServers": {
    "control-plane": {
      "command": "node",
      "args": [
        "packages/mcp-server/dist/server.js"
      ],
      "env": {}
    },
    "code-review-graph": {
      "command": "uvx",
      "args": [
        "code-review-graph",
        "serve"
      ],
      "type": "stdio"
    }
  }
}
