{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:3100/",
        "http://127.0.0.1:3100/agents",
        "http://127.0.0.1:3100/sessions",
        "http://127.0.0.1:3100/sessions/overview",
        "http://127.0.0.1:3100/sessions/costs",
        "http://127.0.0.1:3100/sessions/activity",
        "http://127.0.0.1:3100/sessions/tools",
        "http://127.0.0.1:3100/sessions/projects",
        "http://127.0.0.1:3100/kanban",
        "http://127.0.0.1:3100/mcps",
        "http://127.0.0.1:3100/channels",
        "http://127.0.0.1:3100/replay",
        "http://127.0.0.1:3100/webhooks",
        "http://127.0.0.1:3100/skills"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2"],
        "chromeFlags": "--no-sandbox --headless",
        "maxWaitForFcp": 45000,
        "maxWaitForLoad": 60000
      }
    },
    "assert": {
      "preset": "lhci:assertions-legacy",
      "budgetsFile": "./budget.json",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "interaction-to-next-paint": ["warn", { "maxNumericValue": 200 }],
        "total-blocking-time": ["error", { "maxNumericValue": 200 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1800 }],
        "speed-index": ["warn", { "maxNumericValue": 3400 }],
        "uses-http2": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
