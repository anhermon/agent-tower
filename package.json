{
  "name": "modular-agents-control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build:packages": "pnpm --filter \"./packages/**\" -r build",
    "dev": "pnpm build:packages && pnpm --filter @control-plane/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm build:packages && pnpm -r typecheck",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:perf": "playwright test --project=perf",
    "lint": "pnpm typecheck",
    "cp": "node packages/cli/dist/cli.js",
    "mcp-server": "node packages/mcp-server/dist/server.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@biomejs/biome": "^2.4.12",
    "@cyclonedx/cdxgen": "^12.2.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.14.0",
    "@next/eslint-plugin-next": "^16.2.4",
    "@playwright/test": "^1.52.0",
    "@size-limit/file": "^12.1.0",
    "@size-limit/preset-app": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "knip": "^6.6.1",
    "lefthook": "^2.1.6",
    "license-checker-rseidelsohn": "^4.4.2",
    "lint-staged": "^16.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "size-limit": "^12.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.1.2"
  }
}
